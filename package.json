{
  "name": "matcha2d",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:wasm": "npm run build -w packages/physics-rust",
    "build": "npm run build:wasm && npm run build -w packages/types && npm run build -w packages/world && npm run build --workspaces --if-present --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "vite --config vite.demo.config.ts",
    "dev:build": "vite build --config vite.demo.config.ts",
    "preview:demo": "vite preview --config vite.demo.config.ts",
    "serve:static": "node server.js"
  },
  "devDependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
